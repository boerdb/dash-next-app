# Kopieer naar .env.local (niet committen). Zie scripts/db-migration/INFRA.md
#
# --- Productie (Next op 192.168.1.32, publiek via https://dash.clvs.nl) ---

# Verplicht voor weer/energie uit MariaDB (.14): live, historie, Ecowitt-ingest
DATABASE_URL=mysql://dash_app:JOUW_WW@192.168.1.14:3306/weerdata

# Eenmalig op .14: grant-dash-app-32.py, setup-weer-live-table.py,
# setup-energie-dagstart.py, grant-dash-insert-metingen.py

# Ecowitt Customized Server (LAN, niet via de tunnel):
#   http://192.168.1.32:3000/api/weer/ingest
# Upload-interval: 60 s · protocol Ecowitt · antwoord: SUCCESS

# Fallback als DATABASE_URL ontbreekt (oude PHP-route)
WEER_API_BASE=http://192.168.1.52/weer

# Energie live (P1 + water op LAN)
ENERGIE_P1_URL=http://192.168.1.178/api/v1/data
ENERGIE_WATER_URL=http://192.168.1.169/api/v1/data

# --- Optioneel ---

# Redis op .14 (deze app gebruikt het nog niet)
# REDIS_URL=redis://192.168.1.14:6379

# Getijden (standaard Harlingen)
TIDE_LATITUDE=53.1754
TIDE_LONGITUDE=5.4145

# OpenWeather: voorspelling op weer-tab (One Call 3.0 of fallback 2.5)
OPENWEATHER_API_KEY=

# KNMI Data Platform: officiële waarschuwingen (gratis key op developer.dataplatform.knmi.nl)
KNMI_API_KEY=
# Provinciecode voor waarschuwingen (Harlingen = FR)
# KNMI_PROVINCE=FR
